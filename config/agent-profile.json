{
  "agentName": "Juno",
  "agentNameZh": "朱诺",
  "owner": "",
  "ownerEn": "",
  "version": "0.4.1",
  "headquarters": ".",
  "defaultLanguage": "zh-CN",
  "skills": {
    "core": "my-core-agent",
    "chat": "agent-chat",
    "research": "agent-research",
    "writing": "agent-writing",
    "coding": "agent-coding",
    "memory": "agent-memory"
  },
  "knowledgeDir": "knowledge",
  "memoryFiles": {
    "longTerm": "MEMORY.md",
    "daily": "memory/daily"
  },
  "projects": [
    {
      "id": "juno-hq",
      "label": "Juno HQ",
      "path": ".",
      "aliases": ["juno", "朱诺", "总部", "my-ai-agent"]
    }
  ],
  "index": {
    "enabled": true,
    "topK": 10,
    "chunkChars": 900,
    "hybridEmbed": true,
    "hybridAlpha": 0.45,
    "embedModel": "nomic-embed-text:latest",
    "embedApiBase": "http://127.0.0.1:11434",
    "roots": [
      {
        "id": "juno-hq",
        "path": ".",
        "label": "Juno HQ"
      }
    ],
    "extraPaths": [
      "knowledge/conversations/auto"
    ],
    "ignoreDirs": [
      ".git",
      "node_modules",
      ".next",
      "dist",
      "build",
      "__pycache__",
      ".cursor",
      "mcps",
      "assets",
      "vendor"
    ],
    "ignoreExtensions": [
      ".png",
      ".jpg",
      ".jpeg",
      ".gif",
      ".webp",
      ".ico",
      ".zip",
      ".exe",
      ".dll",
      ".woff",
      ".woff2",
      ".mp4",
      ".mp3",
      ".jsonl"
    ],
    "maxFileBytes": 2097152
  },
  "tools": {
    "enabled": true,
    "maxSteps": 40,
    "maxSubagents": 4,
    "readPolicy": "broad",
    "shellPolicy": "open",
    "broadReadRoots": [
      "~",
      "~/Desktop",
      "~/Documents",
      "~/Downloads"
    ],
    "roots": [
      "."
    ],
    "shellAllowlist": [
      "git status",
      "git diff",
      "git log",
      "git add",
      "git commit",
      "npm ",
      "npm test",
      "npm run",
      "npm start",
      "npm install",
      "pnpm ",
      "pnpm run",
      "pnpm test",
      "pnpm install",
      "pnpm dev",
      "pnpm exec",
      "node ",
      "npx ",
      "python ",
      "python -m pytest",
      "python -m ",
      "python scripts/",
      "pytest",
      "pip ",
      "pip install",
      "curl ",
      "curl.exe ",
      "dir ",
      "ls ",
      "type ",
      "tree ",
      "findstr ",
      "where ",
      "netstat ",
      "tasklist",
      "echo ",
      "Get-Content",
      "Select-String",
      "powershell ",
      "pwsh ",
      "cmd /c",
      "bash ",
      "sh ",
      "make ",
      "ruff check",
      "start ",
      ".\\",
      "cd "
    ],
    "writeRoots": [
      ".",
      "memory",
      "knowledge",
      "__DESKTOP__",
      "~/Documents/juno-artifacts"
    ],
    "webSearch": {
      "enabled": true,
      "provider": "auto"
    }
  }
}
